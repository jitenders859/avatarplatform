# ── Required ─────────────────────────────────────────────────
GEMINI_API_KEY=
JWT_SECRET=change-me-to-a-strong-random-string

# ── Recommended ──────────────────────────────────────────────
# Public Gemini key exposed to embed pages (the SDK opens a websocket
# to Gemini Live from the browser, which requires a key client-side).
# In production, generate a SEPARATE restricted key with quotas.
# Falls back to GEMINI_API_KEY if unset.
PUBLIC_GEMINI_API_KEY=

PORT=8080

# ── Stripe (optional; leave blank to run in demo / no-billing mode) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs from your Stripe dashboard
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
